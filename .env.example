# THE DEAD LAST — environment config (example)
# Copy this file to .env and fill in real values during the wiring pass.
# Never commit the real .env file with live secrets.

# App
APP_ENV=local
APP_URL=https://thedeadlast.com

# Database (SQLite — created by `php web/bin/setup-db.php`)
DB_PATH=./data/graverising.sqlite

# Sessions / auth
SESSION_SECRET=change-me-to-a-long-random-string

# Admin access is granted to users with role='admin' (set via Keeper > Forum
# Users). Auth is unified on the single main-site login (/login) — there is no
# separate Keeper credential.

# Game stats ingest API (api/stats/) — bearer key the game server sends as
# "Authorization: Bearer <GAME_API_KEY>". Rotate for production.
GAME_API_KEY=change-me-to-a-long-random-string

# NPC roster endpoint on the GAME side. Keeper > Messages "Update roster"
# fetches this URL to sync the spawnable-NPC list. Expected JSON:
# {"characters":[{name,gender,role,height},...]} or a bare array of those.
# Sent with the GAME_API_KEY bearer if the game guards it. Blank = disabled.
GAME_ROSTER_URL=https://game.example.com/api/roster

# Items catalog source for Keeper > Items "Update" button (the public GET
# /api/items). The game POSTs its registry to /api/items (replace-all); the
# admin re-fetches this URL to refresh the local view. Blank = prod endpoint.
GAME_ITEMS_URL=https://thedeadlast.com/api/items

# Meshy backlog — shared secret guarding the webhook receiver
# (mesh_payload.php) and the local puller endpoint (/api/meshy). Must match
# the MESHY_WEBHOOK_SECRET the local models/characters/meshy-queue.sh uses.
# Register the webhook in the Meshy dashboard as:
#   https://thedeadlast.com/mesh_payload.php?secret=<MESHY_WEBHOOK_SECRET>
MESHY_WEBHOOK_SECRET=change-me-to-match-the-local-.env-secret
