# The Dead Last — Apache config (host uses Apache, not Caddy).
# Resolve extensionless directory routes like /api/register to their index.php.
DirectoryIndex index.php

# API routing: map the slash-less endpoints straight to their index.php so a
# POST is NOT lost to Apache's dir 301 redirect (/api/register -> /api/register/).
# Both /api/register and /api/register/ now serve the handler without a redirect.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^api/register/?$ api/register/index.php [L]
    RewriteRule ^api/login/?$    api/login/index.php    [L]
    RewriteRule ^api/meshy/?$    api/meshy/index.php    [L]

    # Pretty URLs for the public pages: /register -> register.php, /login ->
    # login.php, etc. Only rewrites when the .php file actually exists and the
    # request isn't already a real file/dir, so it won't shadow api/ or assets.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/$1.php -f
    RewriteRule ^([a-zA-Z0-9_-]+)/?$ $1.php [L]

    # Friendly-URL router fallback: anything that isn't a real file/dir goes
    # through the front controller (router/routes.json).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Fallback for hosts without mod_rewrite: stop Apache appending the 301 slash
# so the POST body is preserved (the handler dir is still resolved).
DirectorySlash Off

# Deny direct web access to sensitive files/dirs (defense in depth;
# .env and the SQLite DB must never be served).
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
<FilesMatch "\.(sqlite|sqlite-journal|sqlite-wal|sqlite-shm|sql|db|db-wal|db-shm)$">
    Require all denied
</FilesMatch>
RedirectMatch 404 ^/data/
RedirectMatch 404 ^/migrations/
RedirectMatch 404 ^/lib/
RedirectMatch 404 ^/bin/
RedirectMatch 404 ^/bbs/lib/
RedirectMatch 404 ^/bbs/data/
RedirectMatch 404 ^/router/
