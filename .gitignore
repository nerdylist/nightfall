# THE DEAD LAST web/ — ignore local secrets and generated data.
# No repo-root .gitignore exists yet in this project, so this covers web/.

# Environment / secrets (never commit real values)
.env
.env.local
api.env

# SQLite database files (generated at runtime, never commit)
data/*.sqlite
data/*.sqlite-journal
data/*.sqlite-wal
data/*.sqlite-shm
data/*.bak-*

# OS cruft
.DS_Store

# Local tooling (Claude Code session/config — not part of the project)
.claude/

# BBS forum (copied app) — same policy: no secrets, no runtime data
bbs/.env
bbs/forum.db
bbs/forum.db-wal
bbs/forum.db-shm
bbs/forum.db.bak-*
bbs/up/*
!bbs/up/index.html
!bbs/up/.htaccess
